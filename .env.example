# Postgres — required (see README: Neon / Docker / Vercel Postgres).
# Example (Neon):
# DATABASE_URL="postgresql://user:password@ep-cool-123.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Required in production on Vercel (32+ chars). Dev uses a built-in default if unset.
# SESSION_PASSWORD=

# Vercel Blob — receipts & pay stub files on serverless (Dashboard → Storage → Blob → token).
# Without this on Vercel, uploads fall back to ephemeral disk and vanish between deployments.
# BLOB_READ_WRITE_TOKEN=

# Optional: Plaid (https://dashboard.plaid.com) — enables /plaid bank link + transaction sync
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox

// Household money app — PostgreSQL for production (Vercel); use Neon/local Postgres for dev.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  createdAt    DateTime  @default(now())
  expenses     Expense[] @relation("ExpenseRecordedBy")
  taxReviewed  Expense[] @relation("ExpenseTaxReviewedBy")
  taxAudits    TaxExpenseAudit[]
  receipts     Receipt[]
  plaidItems   PlaidItem[]
}

/// One row per calendar month (YYYY-MM) for income and rollups
model MonthlyPeriod {
  id           String   @id @default(cuid())
  yearMonth    String   @unique
  /// Legacy: used only when this month has no Paycheck rows yet
  incomeCents  Int      @default(0)
  notes        String?
  expenses     Expense[]
  bills        Bill[]
  budgetPlans  BudgetPlan[]
  receipts     Receipt[]
  paychecks    Paycheck[]
}

/// Actual wage deposits for a month (monthly income = sum of paychecks when any exist)
model Paycheck {
  id              String        @id @default(cuid())
  monthlyPeriodId String
  monthlyPeriod   MonthlyPeriod @relation(fields: [monthlyPeriodId], references: [id], onDelete: Cascade)
  amountCents     Int
  receivedOn      DateTime
  note            String?
  /// HTTPS Blob URL (Vercel Blob) or local basename under data/paystubs/
  imageFilename   String?
  createdAt       DateTime      @default(now())

  @@index([monthlyPeriodId, receivedOn])
}

model Expense {
  id              String        @id @default(cuid())
  monthlyPeriodId String
  monthlyPeriod   MonthlyPeriod @relation(fields: [monthlyPeriodId], references: [id], onDelete: Cascade)
  userId          String?
  user            User?         @relation("ExpenseRecordedBy", fields: [userId], references: [id])
  amountCents     Int
  description     String
  spentAt         DateTime      @default(now())
  source          String        @default("manual")
  /// Dedupe key for CSV imports (e.g. sha256 of date|amount|description)
  importHash      String?
  payee           String?
  /// JSON string array of tags, e.g. ["groceries","work"]
  tagsJson        String?
  /// Same id groups split lines for one purchase
  splitGroupId    String?
  budgetPlanId    String?
  budgetPlan      BudgetPlan?   @relation(fields: [budgetPlanId], references: [id], onDelete: SetNull)
  /// Optional link when this row was posted from a receipt (may share receipt with split lines)
  receiptId       String?
  receipt         Receipt?      @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  /// not_applicable | applicable | applicable_with_documentation — see src/lib/taxCodeGuidance.ts
  taxApplicability String?
  /// Key into built-in guidance (IRC-oriented summaries); viewer link in UI
  taxCodeRefId     String?
  /// Folder key for preparer buckets — see src/lib/taxCategories.ts
  taxCategory         String?
  taxNote             String?
  taxReviewedAt       DateTime?
  taxReviewedByUserId String?
  taxReviewedBy       User?     @relation("ExpenseTaxReviewedBy", fields: [taxReviewedByUserId], references: [id], onDelete: SetNull)
  taxAudits           TaxExpenseAudit[]

  @@index([monthlyPeriodId, importHash])
  @@index([receiptId])
  @@index([taxApplicability, spentAt])
}

/// Append-only log when tax fields on an expense change (household audit trail)
model TaxExpenseAudit {
  id          String   @id @default(cuid())
  expenseId   String
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  /// classify | review | clear | note_update
  action      String
  /// JSON: { applicability?, codeRef?, category?, note?, reviewed? } before/after snapshots
  detailsJson String?
  createdAt   DateTime @default(now())

  @@index([expenseId, createdAt])
  @@index([createdAt])
}

model Bill {
  id              String        @id @default(cuid())
  monthlyPeriodId String
  monthlyPeriod   MonthlyPeriod @relation(fields: [monthlyPeriodId], references: [id], onDelete: Cascade)
  title           String
  amountCents     Int
  dueDate         DateTime
  paid            Boolean       @default(false)
}

model BudgetPlan {
  id              String        @id @default(cuid())
  monthlyPeriodId String
  monthlyPeriod   MonthlyPeriod @relation(fields: [monthlyPeriodId], references: [id], onDelete: Cascade)
  name            String
  category        String?
  limitCents      Int
  note            String?
  /// Money carried into this month for this envelope (from prior month or manual)
  rolledInCents   Int           @default(0)
  expenses        Expense[]
}

/// Global: if expense description contains pattern, add tag (for budget rollups & filters)
model MerchantRule {
  id        String   @id @default(cuid())
  pattern   String
  tag       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

/// Linked bank institution via Plaid Link (access token stored — encrypt in production)
model PlaidItem {
  id                  String    @id @default(cuid())
  itemId              String    @unique
  accessToken         String
  institutionId       String?
  institutionName     String?
  userId              String?
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  transactionsCursor  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

/// Simple manual debt tracking (no bank sync)
model DebtAccount {
  id                  String   @id @default(cuid())
  name                String
  balanceCents        Int
  minimumPaymentCents Int?
  aprPercent          Float?
  note                String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Manual asset/liability for net worth (no bank sync)
model NetWorthAccount {
  id           String   @id @default(cuid())
  kind         String
  name         String
  balanceCents Int
  sortOrder    Int      @default(0)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Point-in-time net worth (totals + optional JSON breakdown)
model NetWorthSnapshot {
  id               String   @id @default(cuid())
  recordedAt       DateTime @default(now())
  assetsCents      Int
  liabilitiesCents Int
  netCents         Int
  note             String?
}

model Receipt {
  id              String         @id @default(cuid())
  monthlyPeriodId String?
  monthlyPeriod   MonthlyPeriod? @relation(fields: [monthlyPeriodId], references: [id])
  userId          String?
  user            User?          @relation(fields: [userId], references: [id])
  filename        String
  note            String?
  totalCents      Int?
  uploadedAt      DateTime       @default(now())
  /// pending | processing | completed | failed | skipped (e.g. unsupported type)
  ocrStatus       String         @default("pending")
  ocrError        String?
  ocrRawText      String?
  /// JSON array: [{ "description": string, "amountCents": number | null }]
  ocrParsedLines  String?
  /// 0–100 from Tesseract when available
  ocrConfidence   Int?
  expenses        Expense[]
}

model ShoppingTrip {
  id         String             @id @default(cuid())
  storeName  String?
  shoppedAt  DateTime           @default(now())
  totalCents Int                @default(0)
  items      ShoppingTripItem[]
}

model ShoppingTripItem {
  id         String       @id @default(cuid())
  tripId     String
  trip       ShoppingTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  name       String
  quantity   Int          @default(1)
  priceCents Int?
}

model SavingsGoal {
  id                String               @id @default(cuid())
  title             String
  targetAmountCents Int
  savedAmountCents  Int                  @default(0)
  deadline          DateTime?
  adjustments       SpendingAdjustment[]
}

/// Planned cuts or extra savings toward a goal (monthly-style amount in cents)
model SpendingAdjustment {
  id            String       @id @default(cuid())
  savingsGoalId String?
  savingsGoal   SavingsGoal? @relation(fields: [savingsGoalId], references: [id])
  label         String
  amountCents   Int
  startsOn      DateTime     @default(now())
}

/// Singleton row (id = 1) for shared household dates
model HouseholdSettings {
  id                       Int       @id @default(1)
  nextPaycheckDate         DateTime?
  /// Target percent of each paycheck to set aside (5, 10, …, 40)
  savingsRatePercentTarget Int       @default(10)
  /// How many paychecks fall in a typical month (splits monthly income for coach math)
  payPeriodsPerMonth       Int       @default(2)
}
